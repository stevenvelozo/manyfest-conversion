{
	"name": "manyfest-conversion",
	"version": "1.0.3",
	"description": "Build mapping manyfests from CSVs, then fill PDF forms and XLSX spreadsheets from platform JSON payloads.",
	"main": "source/Manyfest-Conversion.js",
	"bin": {
		"mfconv": "source/cli/Manyfest-Conversion-CLI-Run.js"
	},
	"scripts": {
		"start": "node source/cli/Manyfest-Conversion-CLI-Run.js",
		"test": "./node_modules/.bin/mocha -u tdd -R spec",
		"tests": "./node_modules/.bin/mocha -u tdd -R spec --grep",
		"coverage": "./node_modules/.bin/nyc --reporter=lcov --reporter=text-lcov ./node_modules/.bin/mocha -- -u tdd -R spec",
		"build": "npx quack build"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "10000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/stevenvelozo/manyfest-conversion.git"
	},
	"keywords": [
		"manyfest",
		"pdf",
		"xlsx",
		"mapping",
		"conversion",
		"forms"
	],
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"dependencies": {
		"exceljs": "^4.4.0",
		"fable": "^3.1.71",
		"fable-serviceproviderbase": "^3.0.19",
		"manyfest": "^1.0.49",
		"pict": "^1.0.365",
		"pict-service-commandlineutility": "^1.0.19",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"chai": "^6.2.2",
		"mocha": "^11.7.5",
		"nyc": "^18.0.0",
		"pict-docuserve": "^0.1.5",
		"quackage": "^1.2.2"
	}
}
